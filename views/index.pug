extends layout

block content
  // Homepage with logo, hero section, and quick links
  section.hero
    img.logo-img(src="/images/logo.png", alt="Downtown Donuts logo")
    h1 Downtown Donuts
    p Fresh donuts, coffee, and family-owned charm since 1992.

    div.hero-buttons
      a.button(href="/menu") View Menu
      a.button.secondary(href="/comments") Leave a Comment

  section.card-section
    article.card
      h2 Fresh Every Morning
      p Our donuts are handcrafted daily with classic flavors and seasonal favorites.

    article.card
      h2 Order Online
      p Order through UberEats, DoorDash, or GrubHub.

    article.card
      h2 Visit Us
      p Stop by 123 Main Street in Downtown.