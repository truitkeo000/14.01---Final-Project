extends layout

block content
  section.menu-hero
    p.eyebrow Freshly Made Daily
    h1 Downtown Donuts Menu
    p Classic donuts, cozy coffee, and breakfast favorites made for downtown mornings.

    .order-links
      a.order-button(href="https://www.ubereats.com/", target="_blank") Order on UberEats
      a.order-button(href="https://www.doordash.com/", target="_blank") Order on DoorDash
      a.order-button(href="https://www.grubhub.com/", target="_blank") Order on GrubHub

  section.menu-container
    .menu-info
      div
        strong OPEN DAILY
        p Mon-Fri 6AM-6PM | Sat-Sun 7AM-4PM
      div
        strong LOCATION
        p 123 Main Street, Downtown
      div
        strong CALL US
        p (555) 867-5309

    h2.section-title Signature Donuts
    p.section-sub Handcrafted fresh every morning

    .donut-grid
      article.donut-card
        .donut-icon 🍩
        h3 Classic Glazed
        p Light, fluffy, and perfectly glazed.
        span.price $2.50

      article.donut-card
        .donut-icon 🥓
        h3 Maple Bacon Bar
        p Maple glaze topped with crispy applewood bacon.
        span.price $3.75

      article.donut-card
        .donut-icon 🍫
        h3 Boston Cream
        p Bavarian cream filling with chocolate ganache.
        span.price $3.50

      article.donut-card
        .donut-icon 🫐
        h3 Blueberry Cake
        p Dense cake donut bursting with blueberry flavor.
        span.price $3.25

      article.donut-card
        .donut-icon ✨
        h3 Cinnamon Sugar Twist
        p Hand-twisted and tossed in cinnamon sugar.
        span.price $2.75

      article.donut-card
        .donut-icon 🍓
        h3 Strawberry Frosted
        p Strawberry glaze with rainbow sprinkles.
        span.price $3.00

      article.donut-card
        .donut-icon 🍫
        h3 Chocolate Old Fashioned
        p Sour cream donut with rich chocolate glaze.
        span.price $3.25

      article.donut-card
        .donut-icon 🍯
        h3 Dulce de Leche
        p Caramel cream filled, drizzled with dulce de leche.
        span.price $3.75

      article.donut-card
        .donut-icon 🍋
        h3 Lemon Poppy Seed
        p Bright lemon glaze with poppy seed crunch.
        span.price $3.50

      article.donut-card
        .donut-icon 🥜
        h3 PB & J
        p Peanut butter glaze with raspberry jam filling.
        span.price $3.75

    .special-box
        h3 Donut Holes
        p Mix and match flavors!
        p Half Dozen $4.50 | Dozen $7.99

    h2.section-title Coffee & Espresso
    p.section-sub Locally roasted beans • Always fresh

    .drink-table
      .drink-row.drink-header
        span Drink
        span Small
        span Medium
        span Large

      .drink-row
        span Drip Coffee
        span $2.25
        span $2.75
        span $3.25

      .drink-row
        span Cold Brew
        span $3.50
        span $4.00
        span $4.50

      .drink-row
        span Americano
        span $3.25
        span $3.75
        span $4.25

      .drink-row
        span Latte
        span $4.25
        span $4.75
        span $5.25

      .drink-row
        span Cappuccino
        span $4.25
        span $4.75
        span $5.25

      .drink-row
        span Mocha
        span $4.75
        span $5.25
        span $5.75

      .drink-row
        span Vanilla Chai Latte
        span $4.50
        span $5.00
        span $5.50

    h2.section-title Breakfast Bites

    .menu-list
      .menu-item
        div
          strong Egg & Cheese Croissant
          p.desc Buttery croissant with egg and melted cheese.
        span.price $5.50

      .menu-item
        div
          strong Bacon Breakfast Sandwich
          p.desc Bacon, egg, and cheese on a toasted bun.
        span.price $6.25

      .menu-item
        div
          strong Avocado Toast
          p.desc Toasted bread with avocado and seasoning.
        span.price $5.75

      .menu-item
        div
          strong Yogurt Parfait
          p.desc Yogurt layered with fruit and granola.
        span.price $4.50

      p(style="text-align:center; margin-top:30px; color:#555;")
        | Catering available! Call (555) 867-5309 or email catering@downtowndonuts.com